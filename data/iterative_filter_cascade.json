  "evidence_label": "observed_operator_characterization_not_official_pipeline",
  "interpretation": "the operator is non-idempotent in every chain: after the first cleanup, newly relative minima are reclassified as outliers; repeated application removes extension, connector, and core evidence until only two or three reference-near views remain",
  "interpretation_boundary": "this collapse is a characterization of repeated score use, not a claim that the released one-pass RobustVGGT pipeline performs repeated filtering",
  "schema_version": 1,
  "scope": "the released score/filter is reapplied until a fixed point; RobustVGGT itself applies the filter once, so this tests whether the score can serve as an idempotent view-validity predicate",
  "status": "complete"
}
